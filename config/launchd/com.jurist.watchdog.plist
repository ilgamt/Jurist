<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jurist.watchdog</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/a1/Jurist/scripts/jurist_watchdog.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/a1/Jurist</string>

  <key>StandardOutPath</key>
  <string>/Users/a1/Jurist/logs/watchdog.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/a1/Jurist/logs/watchdog.err.log</string>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
</dict>
</plist>
