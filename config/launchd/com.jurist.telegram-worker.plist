<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jurist.telegram-worker</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/ilgam/Jurist/.venv/bin/jurist</string>
    <string>telegram-service</string>
    <string>--worker-only</string>
    <string>--process-interval-seconds</string>
    <string>5</string>
    <string>--case-budget-usd</string>
    <string>10</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/ilgam/Jurist</string>

  <key>StandardOutPath</key>
  <string>/Users/ilgam/Jurist/logs/telegram-worker.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/ilgam/Jurist/logs/telegram-worker.err.log</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONUNBUFFERED</key>
    <string>1</string>
  </dict>
</dict>
</plist>
