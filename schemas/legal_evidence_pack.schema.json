{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "legal_evidence_pack.schema.json",
  "type": "object",
  "required": [
    "legal_questions",
    "sources",
    "source_gaps",
    "overall_confidence",
    "requires_lawyer_review"
  ],
  "properties": {
    "legal_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_id", "question", "clause_references"],
        "properties": {
          "question_id": { "type": "string" },
          "question": { "type": "string" },
          "clause_references": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "source_type",
          "title",
          "url_or_citation",
          "retrieved_at",
          "legal_question_ids",
          "relevance",
          "confidence",
          "primary_source"
        ],
        "properties": {
          "source_id": { "type": "string" },
          "source_type": {
            "type": "string",
            "enum": [
              "statute",
              "court_case",
              "supreme_court_position",
              "official_explanation",
              "secondary_source",
              "user_provided"
            ]
          },
          "title": { "type": "string" },
          "url_or_citation": { "type": "string" },
          "publication_date": { "type": "string" },
          "retrieved_at": { "type": "string" },
          "legal_question_ids": { "type": "array", "items": { "type": "string" } },
          "summary": { "type": "string" },
          "relevance": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "primary_source": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "source_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gap", "why_it_matters"],
        "properties": {
          "gap": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "suggested_next_search": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "requires_lawyer_review": { "type": "boolean" }
  },
  "additionalProperties": false
}
