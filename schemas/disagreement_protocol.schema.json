{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "disagreement_protocol.schema.json",
  "type": "object",
  "required": ["schema_version", "case_id", "protocol_version", "items"],
  "properties": {
    "schema_version": { "const": "0.1" },
    "case_id": { "type": "string" },
    "protocol_version": { "type": "string" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/disagreement_item" }
    },
    "global_comments": { "type": "array", "items": { "type": "string" }, "default": [] },
    "unresolved_questions": { "type": "array", "items": { "type": "string" }, "default": [] },
    "approval_status": {
      "type": "string",
      "enum": ["draft", "awaiting_user_approval", "approved_for_export", "rejected"],
      "default": "draft"
    }
  },
  "$defs": {
    "disagreement_item": {
      "type": "object",
      "required": [
        "item_id",
        "clause_reference",
        "current_wording",
        "proposed_wording",
        "rationale",
        "priority",
        "requires_human_legal_review"
      ],
      "properties": {
        "item_id": { "type": "string" },
        "clause_reference": { "type": "string" },
        "current_wording": { "type": "string" },
        "proposed_wording": { "type": "string" },
        "rationale": { "type": "string" },
        "risk_if_unchanged": { "type": "string" },
        "priority": { "type": "string", "enum": ["must_have", "important", "negotiable"] },
        "fallback_position": { "type": "string" },
        "evidence_refs": { "type": "array", "items": { "type": "string" }, "default": [] },
        "practice_support": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "practice_case_count": { "type": "integer", "minimum": 0 },
            "case_numbers": { "type": "array", "items": { "type": "string" }, "default": [] },
            "notes": { "type": "array", "items": { "type": "string" }, "default": [] }
          },
          "additionalProperties": false
        },
        "owner": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "requires_human_legal_review": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
